
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * YIELD INSIGHTS TERMINAL - SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a Database-Backed Access Control (DBAC) model.
     * Read access to financial silos is public to support Demo Mode.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isAdminAndExists() {
      return isAdmin() && resource != null;
    }

    function isUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == userId;
      allow update: if isAdminAndExists() && isUnchanged('id');
      allow delete: if isAdminAndExists();
    }

    // Institutional Silo: Public read for terminal performance
    match /market_data/{symbol} {
      allow get, list: if true; 
      allow write: if true; // Allowed for demo session rehydration
    }

    match /tickers/{tickerId} {
      allow get, list: if true;
      allow create: if true; // Allow demo synthesis
      allow update: if true;
      allow delete: if isAdminAndExists();

      match /supplyChainNodes/{nodeId} {
        allow get, list: if true;
        allow create, update: if true;
        allow delete: if isAdminAndExists();
      }

      match /supplyChainLinks/{linkId} {
        allow get, list: if true;
        allow create, update: if true;
        allow delete: if isAdminAndExists();
      }
    }

    match /logs/{logId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /appSettings/{settingId} {
      allow get: if true;
      allow list: if true;
      allow write: if true;
    }
  }
}
